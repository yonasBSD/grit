#!/bin/sh
# Shell reimplementation of git's t/helper/test-fake-ssh.c for the grit test
# harness (which does not compile C helpers). It records the SSH argv that the
# client passes into "$TRASH_DIRECTORY/ssh-output" and then evaluates the last
# argument through the shell, exactly like the upstream helper.

if test -z "$TRASH_DIRECTORY"
then
	echo "Need a TRASH_DIRECTORY!" >&2
	exit 1
fi

# Build the "ssh: <arg1> <arg2> ..." line. The first field is always the literal
# "ssh:" (replacing argv[0]); remaining fields are the arguments verbatim.
{
	printf 'ssh:'
	for arg
	do
		printf ' %s' "$arg"
	done
	printf '\n'
} >"$TRASH_DIRECTORY/ssh-output"

# Nothing else to run when no command was supplied.
if test "$#" -lt 1
then
	exit 0
fi

# Evaluate the *last* argument via the shell, like run_command(use_shell=1).
eval "$(eval 'printf %s "${'"$#"'}"')"
