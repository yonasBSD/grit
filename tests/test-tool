#!/bin/sh
# Minimal test-tool stub for grit tests
# Implements the most-used subcommands from git's test-tool
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

global_c_dir=""
while [ "$1" = "-C" ]; do
  if [ $# -lt 2 ]; then
    echo "test-tool: option requires an argument -- C" >&2
    exit 129
  fi
  global_c_dir="$2"
  shift 2
done

git_with_global_c() {
  if [ -n "$global_c_dir" ]; then
    git -C "$global_c_dir" "$@"
  else
    git "$@"
  fi
}

case "$1" in
  chmtime)
    shift
    usage() {
      echo "usage: test-tool chmtime (-v|--verbose|-g|--get) (+|=|=+|=-|-)<seconds> <file>..." >&2
      exit 1
    }
    is_int() {
      case "$1" in
        ''|+|-) return 1 ;;
        [+-][0-9]*|[0-9]*) return 0 ;;
        *) return 1 ;;
      esac
    }
    parse_timespec() {
      _timespec="$1"
      CHM_SET_EQ=0
      if [ "${_timespec#=}" != "$_timespec" ]; then
        CHM_SET_EQ=1
        _timespec="${_timespec#=}"
        if [ "${_timespec#+}" != "$_timespec" ]; then
          CHM_SET_EQ=2
          _timespec="${_timespec#+}"
        fi
      fi
      if ! is_int "$_timespec"; then
        return 1
      fi
      CHM_SET_TIME="$_timespec"
      if [ "$CHM_SET_EQ" -eq 2 ] || { [ "$CHM_SET_EQ" -eq 1 ] && [ "$CHM_SET_TIME" -lt 0 ]; }; then
        _now=$(date +%s)
        CHM_SET_TIME=$((CHM_SET_TIME + _now))
      fi
      return 0
    }

    CHM_GET=0
    CHM_VERBOSE=0
    CHM_SET_EQ=0
    CHM_SET_TIME=0

    [ $# -lt 2 ] && usage

    case "$1" in
      --get|-g)
        CHM_GET=1
        shift
        ;;
      --verbose|-v)
        CHM_VERBOSE=1
        shift
        ;;
    esac

    [ $# -eq 0 ] && usage

    if parse_timespec "$1"; then
      shift
    elif [ "$CHM_GET" -eq 0 ] && [ "$CHM_VERBOSE" -eq 0 ]; then
      usage
    fi

    [ $# -eq 0 ] && usage

    for f in "$@"; do
      cur=$(stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null) || {
        echo "Failed to stat $f: skipping" >&2
        continue
      }

      if [ "$CHM_SET_EQ" -eq 0 ]; then
        new=$((cur + CHM_SET_TIME))
      else
        new=$CHM_SET_TIME
      fi

      if [ "$new" -lt 0 ]; then
        shown=0
      else
        shown=$new
      fi

      if [ "$CHM_GET" -eq 1 ]; then
        printf '%s\n' "$shown"
      elif [ "$CHM_VERBOSE" -eq 1 ]; then
        printf '%s\t%s\n' "$shown" "$f"
      fi

      if [ "$new" -ne "$cur" ]; then
        touch -d "@$new" "$f" 2>/dev/null ||
          python3 -c 'import os, sys; ts=int(sys.argv[1]); os.utime(sys.argv[2], (ts, ts))' "$new" "$f" 2>/dev/null ||
          {
            echo "Failed to modify time on $f" >&2
            exit 1
          }
      fi
    done
    ;;
  sha1|sha256)
    # Git's test-tool $(test_oid algo) -b reads stdin and writes the raw digest (pack trailer).
    _algo="$1"
    shift
    if [ "${1:-}" = "-b" ]; then
      shift
      python3 -c "import sys, hashlib; h = getattr(hashlib, '${_algo}')(); h.update(sys.stdin.buffer.read()); sys.stdout.buffer.write(h.digest())"
    else
      case "$_algo" in
      sha1) sha1sum | cut -d' ' -f1 ;;
      sha256) sha256sum | cut -d' ' -f1 ;;
      esac
    fi
    ;;
  pack-deltas)
    shift
    _grit="${GUST_BIN:-$SCRIPT_DIR/grit}"
    if [ -n "$global_c_dir" ]; then
      exec "$_grit" -C "$global_c_dir" test-tool pack-deltas "$@"
    fi
    exec "$_grit" test-tool pack-deltas "$@" ;;
  genrandom)
    shift
    exec "$SCRIPT_DIR/grit" test-tool genrandom "$@" ;;
  genzeros)
    count="${2:-0}"
    dd if=/dev/zero bs=1 count="$count" 2>/dev/null ;;
  mktemp)
    shift
    if [ $# -ne 1 ]; then
      echo "test-tool mktemp: expected one template argument" >&2
      exit 1
    fi
    template="$1"
    tmp_path="$(mktemp "$template" 2>/dev/null)" || {
      echo "mktemp: failed to create temporary file from '$template'" >&2
      exit 1
    }
    rm -f "$tmp_path"
    ;;
  regex)
    shift
    if [ "$1" = "--bug" ]; then
      [ $# -eq 1 ] || {
        echo "test-tool regex: --bug takes no additional arguments" >&2
        exit 1
      }
      exit 0
    fi

    silent=0
    if [ "$1" = "--silent" ]; then
      silent=1
      shift
    fi

    if [ $# -lt 1 ]; then
      echo "test-tool regex: missing pattern" >&2
      exit 1
    fi

    pattern="$1"
    shift
    subject=""
    has_subject=0
    if [ $# -gt 0 ]; then
      subject="$1"
      has_subject=1
      shift
    fi

    regex_flags=""
    while [ $# -gt 0 ]; do
      case "$1" in
        ICASE)
          regex_flags="${regex_flags}i"
          ;;
        NEWLINE)
          regex_flags="${regex_flags}m"
          ;;
        EXTENDED|NOTBOL|NOTEOL|STARTEND)
          ;;
        *)
          echo "test-tool regex: do not recognize flag $1" >&2
          exit 1
          ;;
      esac
      shift
    done

    python3 - "$pattern" "$subject" "$has_subject" "$silent" "$regex_flags" <<'PY'
import re
import sys

pattern, subject, has_subject, silent, flag_str = sys.argv[1:]
flags = 0
if "i" in flag_str:
    flags |= re.IGNORECASE
if "m" in flag_str:
    flags |= re.MULTILINE

try:
    rx = re.compile(pattern, flags)
except re.error as exc:
    if silent != "1":
        print(f"failed regcomp() for pattern '{pattern}' ({exc})", file=sys.stderr)
    sys.exit(1)

if has_subject != "1":
    sys.exit(0)

if rx.search(subject) is None:
    sys.exit(1)

sys.exit(0)
PY
    ;;
  read-cache)
    shift
    _grit="${GUST_BIN:-$SCRIPT_DIR/grit}"
    if [ ! -x "$_grit" ]; then
      echo "test-tool read-cache: no grit binary (set GUST_BIN or build: tests/grit)" >&2
      exit 1
    fi
    if [ -n "$global_c_dir" ]; then
      exec "$_grit" -C "$global_c_dir" test-tool read-cache "$@"
    fi
    exec "$_grit" test-tool read-cache "$@" ;;
  dump-cache-tree)
    shift
    _grit="${GUST_BIN:-$SCRIPT_DIR/grit}"
    if [ ! -x "$_grit" ]; then
      echo "test-tool dump-cache-tree: no grit binary (set GUST_BIN or build: tests/grit)" >&2
      exit 1
    fi
    exec "$_grit" test-tool dump-cache-tree "$@" ;;
  scrap-cache-tree)
    shift
    _grit="${GUST_BIN:-$SCRIPT_DIR/grit}"
    if [ ! -x "$_grit" ]; then
      echo "test-tool scrap-cache-tree: no grit binary (set GUST_BIN or build: tests/grit)" >&2
      exit 1
    fi
    exec "$_grit" test-tool scrap-cache-tree "$@" ;;
  date)
    shift
    exec "$GUST_BIN" test-tool date "$@"
    ;;
  env-helper)
    shift
    env_helper_usage() {
      echo "test-tool env-helper --type=[bool|ulong] <options> <env-var>" >&2
    }

    # Read config early so include-cycle failures are reported before
    # any later path handling (mirrors behavior tested in t0017).
    # Intentionally do NOT honor -C here.
    git config -l >/dev/null || exit 1

    type=""
    default=""
    default_set=0
    exit_code=0

    parse_bool_value() {
      lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
      case "$lower" in
        true|yes|on|1)
          parsed_bool=1
          return 0
          ;;
        false|no|off|0)
          parsed_bool=0
          return 0
          ;;
      esac
      return 1
    }

    parse_ulong_value() {
      case "$1" in
        ''|*[!0-9]*)
          return 1
          ;;
        *)
          parsed_ulong="$1"
          return 0
          ;;
      esac
    }

    env_var=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --type=*)
          type="${1#--type=}"
          shift
          ;;
        --type)
          shift
          [ $# -gt 0 ] || { env_helper_usage; exit 129; }
          type="$1"
          shift
          ;;
        --default=*)
          default_set=1
          default="${1#--default=}"
          shift
          ;;
        --default)
          shift
          [ $# -gt 0 ] || { env_helper_usage; exit 129; }
          default_set=1
          default="$1"
          shift
          ;;
        --exit-code)
          exit_code=1
          shift
          ;;
        --)
          shift
          continue
          ;;
        *)
          if [ -n "$env_var" ]; then
            env_helper_usage
            exit 129
          fi
          env_var="$1"
          shift
          ;;
        -*)
          env_helper_usage
          exit 129
          ;;
      esac
    done

    [ -n "$type" ] || { env_helper_usage; exit 129; }
    [ -n "$env_var" ] || { env_helper_usage; exit 129; }
    if [ "$default_set" -eq 1 ] && [ -z "$default" ]; then
      env_helper_usage
      exit 129
    fi

    eval "env_is_set=\${$env_var+x}"
    eval "env_val=\${$env_var-}"

    case "$type" in
      bool)
        if [ "$default_set" -eq 1 ]; then
          parse_bool_value "$default" || { env_helper_usage; exit 129; }
          default_bool="$parsed_bool"
        else
          default_bool=0
        fi

        if [ "$env_is_set" = "x" ]; then
          if parse_bool_value "$env_val"; then
            result_bool="$parsed_bool"
          else
            result_bool="$default_bool"
          fi
        else
          result_bool="$default_bool"
        fi

        if [ "$exit_code" -eq 0 ]; then
          if [ "$result_bool" -eq 1 ]; then
            echo true
          else
            echo false
          fi
        fi
        [ "$result_bool" -eq 1 ]
        ;;
      ulong)
        if [ "$default_set" -eq 1 ]; then
          parse_ulong_value "$default" || { env_helper_usage; exit 129; }
          default_ulong="$parsed_ulong"
        else
          default_ulong=0
        fi

        if [ "$env_is_set" = "x" ]; then
          if parse_ulong_value "$env_val"; then
            result_ulong="$parsed_ulong"
          else
            result_ulong="$default_ulong"
          fi
        else
          result_ulong="$default_ulong"
        fi

        if [ "$exit_code" -eq 0 ]; then
          echo "$result_ulong"
        fi
        [ "$result_ulong" -ne 0 ]
        ;;
      *)
        env_helper_usage
        exit 129
        ;;
    esac ;;
  parse-pathspec-file)
    shift
    pathspec_from_file=""
    pathspec_file_nul=0
    while [ $# -gt 0 ]; do
      case "$1" in
        --pathspec-from-file=*)
          pathspec_from_file="${1#--pathspec-from-file=}"
          shift
          ;;
        --pathspec-from-file)
          shift
          [ $# -gt 0 ] || {
            echo "test-tool parse-pathspec-file: --pathspec-from-file requires an argument" >&2
            exit 129
          }
          pathspec_from_file="$1"
          shift
          ;;
        --pathspec-file-nul)
          pathspec_file_nul=1
          shift
          ;;
        --)
          shift
          ;;
        *)
          echo "test-tool parse-pathspec-file: unknown option '$1'" >&2
          exit 129
          ;;
      esac
    done

    if [ -z "$pathspec_from_file" ]; then
      echo "test-tool parse-pathspec-file: missing --pathspec-from-file" >&2
      exit 129
    fi

    if [ "$pathspec_from_file" = "-" ]; then
      input_path="/dev/stdin"
    else
      input_path="$pathspec_from_file"
    fi

    perl -e '
      use strict;
      use warnings;
      my ($path, $nul_mode) = @ARGV;
      local $/;
      open my $fh, "<:raw", $path or die "cannot open $path: $!";
      my $data = <$fh>;
      $data = "" unless defined $data;

      sub unquote_c_style {
        my ($s) = @_;
        return $s unless $s =~ /^"(.*)"$/s;
        my $body = $1;
        my $out = "";
        my $i = 0;
        while ($i < length($body)) {
          my $ch = substr($body, $i, 1);
          if ($ch ne "\\") {
            $out .= $ch;
            $i++;
            next;
          }
          $i++;
          last if $i >= length($body);
          my $esc = substr($body, $i, 1);
          if ($esc =~ /[0-7]/) {
            my $oct = $esc;
            $i++;
            for (1..2) {
              last if $i >= length($body);
              my $n = substr($body, $i, 1);
              last unless $n =~ /[0-7]/;
              $oct .= $n;
              $i++;
            }
            $out .= chr(oct($oct));
            next;
          }
          my %map = (
            "a" => "\a", "b" => "\b", "f" => "\f",
            "n" => "\n", "r" => "\r", "t" => "\t",
            "v" => chr(11), "\\" => "\\", "\"" => "\""
          );
          if (exists $map{$esc}) {
            $out .= $map{$esc};
          } else {
            $out .= $esc;
          }
          $i++;
        }
        return $out;
      }

      my @items;
      if ($nul_mode) {
        @items = split(/\0/, $data, -1);
        pop @items if @items && $items[-1] eq "";
      } else {
        @items = split(/\n/, $data, -1);
        pop @items if @items && $items[-1] eq "";
        @items = map {
          my $v = $_;
          $v =~ s/\r$//;
          unquote_c_style($v);
        } @items;
      }

      for my $it (@items) {
        print $it, "\n";
      }
    ' "$input_path" "$pathspec_file_nul"
    ;;
  json-writer)
    shift
    pretty=0
    if [ "$1" = "-u" ] || [ "$1" = "--unit" ]; then
      # Upstream helper runs internal regression tests; for our shim the
      # scripted JSON emitter is the compatibility surface exercised by tests.
      exit 0
    fi
    if [ "$1" = "-p" ] || [ "$1" = "--pretty" ]; then
      pretty=1
      shift
    fi
    python3 -c '
import json
import sys

pretty = (len(sys.argv) > 1 and sys.argv[1] == "1")

lines = []
for raw in sys.stdin:
    line = raw.strip()
    if line:
        lines.append(line)

if not lines:
    sys.exit(0)

def fail(msg: str) -> None:
    print(msg, file=sys.stderr)
    sys.exit(1)

first = lines[0]
if first == "object":
    root = {}
elif first == "array":
    root = []
else:
    fail("expected first line to be object or array")

stack = [root]

def current():
    return stack[-1]

for line in lines[1:]:
    parts = line.split()
    if not parts:
        continue
    verb = parts[0]

    if verb == "end":
        if not stack:
            fail("unexpected end")
        stack.pop()
        continue

    cur = current() if stack else None
    if cur is None:
        fail("json already terminated")

    if verb == "object-string":
        key, value = parts[1], parts[2]
        if not isinstance(cur, dict):
            fail("object-string outside object")
        cur[key] = value
    elif verb == "object-int":
        key, value = parts[1], int(parts[2], 10)
        if not isinstance(cur, dict):
            fail("object-int outside object")
        cur[key] = value
    elif verb == "object-double":
        key = parts[1]
        scale = int(parts[2], 10)
        value = round(float(parts[3]), scale)
        if not isinstance(cur, dict):
            fail("object-double outside object")
        cur[key] = value
    elif verb == "object-true":
        key = parts[1]
        if not isinstance(cur, dict):
            fail("object-true outside object")
        cur[key] = True
    elif verb == "object-false":
        key = parts[1]
        if not isinstance(cur, dict):
            fail("object-false outside object")
        cur[key] = False
    elif verb == "object-null":
        key = parts[1]
        if not isinstance(cur, dict):
            fail("object-null outside object")
        cur[key] = None
    elif verb == "object-object":
        key = parts[1]
        if not isinstance(cur, dict):
            fail("object-object outside object")
        sub = {}
        cur[key] = sub
        stack.append(sub)
    elif verb == "object-array":
        key = parts[1]
        if not isinstance(cur, dict):
            fail("object-array outside object")
        sub = []
        cur[key] = sub
        stack.append(sub)
    elif verb == "array-string":
        if not isinstance(cur, list):
            fail("array-string outside array")
        cur.append(parts[1])
    elif verb == "array-int":
        if not isinstance(cur, list):
            fail("array-int outside array")
        cur.append(int(parts[1], 10))
    elif verb == "array-double":
        if not isinstance(cur, list):
            fail("array-double outside array")
        scale = int(parts[1], 10)
        cur.append(round(float(parts[2]), scale))
    elif verb == "array-true":
        if not isinstance(cur, list):
            fail("array-true outside array")
        cur.append(True)
    elif verb == "array-false":
        if not isinstance(cur, list):
            fail("array-false outside array")
        cur.append(False)
    elif verb == "array-null":
        if not isinstance(cur, list):
            fail("array-null outside array")
        cur.append(None)
    elif verb == "array-object":
        if not isinstance(cur, list):
            fail("array-object outside array")
        sub = {}
        cur.append(sub)
        stack.append(sub)
    elif verb == "array-array":
        if not isinstance(cur, list):
            fail("array-array outside array")
        sub = []
        cur.append(sub)
        stack.append(sub)
    else:
        fail(f"unrecognized token: {verb}")

if stack:
    fail("json not terminated")

if pretty:
    print(json.dumps(root, ensure_ascii=False, indent=2))
else:
    print(json.dumps(root, ensure_ascii=False, separators=(",", ":")))
' "$pretty"
    ;;
  dir-iterator)
    shift
    pedantic=0
    if [ "$1" = "--pedantic" ]; then
      pedantic=1
      shift
    fi
    if [ $# -ne 1 ]; then
      echo "dir-iterator needs exactly one non-option argument" >&2
      exit 1
    fi
    root="$1"

    if [ ! -e "$root" ]; then
      echo "dir_iterator_begin failure: ENOENT"
      exit 1
    fi
    if [ ! -d "$root" ] || [ -L "$root" ]; then
      echo "dir_iterator_begin failure: ENOTDIR"
      exit 1
    fi

    list_dir_iterator() {
      current_dir="$1"
      current_prefix="$2"

      if [ ! -r "$current_dir" ] || [ ! -x "$current_dir" ]; then
        if [ "$pedantic" -eq 1 ]; then
          echo "dir_iterator_advance failure"
          return 1
        fi
        return 0
      fi

      found_entry=0
      for entry in "$current_dir"/*; do
        if [ ! -e "$entry" ] && [ ! -L "$entry" ]; then
          continue
        fi
        found_entry=1
        name=$(basename "$entry")
        rel_path="$name"
        if [ -n "$current_prefix" ]; then
          rel_path="$current_prefix/$name"
        fi

        if [ -L "$entry" ]; then
          printf '[s] (%s) [%s] %s/%s\n' "$rel_path" "$name" "$root" "$rel_path"
          continue
        fi

        if [ -d "$entry" ]; then
          printf '[d] (%s) [%s] %s/%s\n' "$rel_path" "$name" "$root" "$rel_path"
          (
            list_dir_iterator "$entry" "$rel_path"
          ) || return 1
        elif [ -f "$entry" ]; then
          printf '[f] (%s) [%s] %s/%s\n' "$rel_path" "$name" "$root" "$rel_path"
        fi
      done
      if [ "$found_entry" -eq 0 ]; then
        return 0
      fi
      return 0
    }

    list_dir_iterator "$root" "" || exit 1
    ;;
  bloom)
    shift
    subcmd="$1"
    shift || true
    python3 - "$subcmd" "$@" <<'PY'
import subprocess
import sys

HASH_VERSION = 1
NUM_HASHES = 7
BITS_PER_ENTRY = 10
MAX_CHANGED_PATHS = 512
SEED0 = 0x293AE76F
SEED1 = 0x7E646E2C

def u32(v: int) -> int:
    return v & 0xFFFFFFFF

def rotl32(value: int, count: int) -> int:
    count &= 31
    return u32((value << count) | (value >> ((-count) & 31)))

def cchar_to_u32(byte: int) -> int:
    # Match C signed-char to uint32_t cast used by bloom v1.
    signed = byte if byte < 128 else byte - 256
    return u32(signed)

def murmur3_seeded_v2(seed: int, data: bytes) -> int:
    c1 = 0xCC9E2D51
    c2 = 0x1B873593
    r1 = 15
    r2 = 13
    m = 5
    n = 0xE6546B64

    seed = u32(seed)
    len4 = len(data) // 4
    for i in range(len4):
        b1 = data[4 * i]
        b2 = data[4 * i + 1] << 8
        b3 = data[4 * i + 2] << 16
        b4 = data[4 * i + 3] << 24
        k = u32(b1 | b2 | b3 | b4)
        k = u32(k * c1)
        k = rotl32(k, r1)
        k = u32(k * c2)
        seed ^= k
        seed = u32(rotl32(seed, r2) * m + n)

    tail = data[len4 * 4 :]
    k1 = 0
    rem = len(data) & 3
    if rem == 3:
        k1 ^= tail[2] << 16
    if rem >= 2:
        k1 ^= tail[1] << 8
    if rem >= 1:
        k1 ^= tail[0]
        k1 = u32(k1 * c1)
        k1 = rotl32(k1, r1)
        k1 = u32(k1 * c2)
        seed ^= k1

    seed ^= len(data)
    seed ^= (seed >> 16)
    seed = u32(seed * 0x85EBCA6B)
    seed ^= (seed >> 13)
    seed = u32(seed * 0xC2B2AE35)
    seed ^= (seed >> 16)
    return u32(seed)

def murmur3_seeded_v1(seed: int, data: bytes) -> int:
    c1 = 0xCC9E2D51
    c2 = 0x1B873593
    r1 = 15
    r2 = 13
    m = 5
    n = 0xE6546B64

    seed = u32(seed)
    len4 = len(data) // 4
    for i in range(len4):
        b1 = cchar_to_u32(data[4 * i])
        b2 = u32(cchar_to_u32(data[4 * i + 1]) << 8)
        b3 = u32(cchar_to_u32(data[4 * i + 2]) << 16)
        b4 = u32(cchar_to_u32(data[4 * i + 3]) << 24)
        k = u32(b1 | b2 | b3 | b4)
        k = u32(k * c1)
        k = rotl32(k, r1)
        k = u32(k * c2)
        seed ^= k
        seed = u32(rotl32(seed, r2) * m + n)

    tail = data[len4 * 4 :]
    k1 = 0
    rem = len(data) & 3
    if rem == 3:
        k1 ^= u32(cchar_to_u32(tail[2]) << 16)
    if rem >= 2:
        k1 ^= u32(cchar_to_u32(tail[1]) << 8)
    if rem >= 1:
        k1 ^= cchar_to_u32(tail[0])
        k1 = u32(k1 * c1)
        k1 = rotl32(k1, r1)
        k1 = u32(k1 * c2)
        seed ^= k1

    seed ^= len(data)
    seed ^= (seed >> 16)
    seed = u32(seed * 0x85EBCA6B)
    seed ^= (seed >> 13)
    seed = u32(seed * 0xC2B2AE35)
    seed ^= (seed >> 16)
    return u32(seed)

def bloom_hashes_for_string(text: str, version: int) -> list[int]:
    raw = text.encode("utf-8", "surrogatepass")
    if version == 2:
        h0 = murmur3_seeded_v2(SEED0, raw)
        h1 = murmur3_seeded_v2(SEED1, raw)
    else:
        h0 = murmur3_seeded_v1(SEED0, raw)
        h1 = murmur3_seeded_v1(SEED1, raw)
    return [u32(h0 + i * h1) for i in range(NUM_HASHES)]

def add_hashes_to_filter(hashes: list[int], data: bytearray) -> None:
    mod = len(data) * 8
    for hv in hashes:
        pos = hv % mod
        block = pos // 8
        data[block] |= (1 << (pos & 7))

def print_filter(data: bytearray) -> None:
    print(f"Filter_Length:{len(data)}")
    print("Filter_Data:" + "".join(f"{b:02x}|" for b in data))

def cmd_get_murmur3(args: list[str]) -> int:
    if len(args) != 1:
        return 129
    hv = murmur3_seeded_v2(0, args[0].encode("utf-8", "surrogatepass"))
    print(f"Murmur3 Hash with seed=0:0x{hv:08x}")
    return 0

def cmd_get_murmur3_seven_highbit(args: list[str]) -> int:
    if args:
        return 129
    raw = bytes([0x99, 0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF])
    hv = murmur3_seeded_v2(0, raw)
    print(f"Murmur3 Hash with seed=0:0x{hv:08x}")
    return 0

def cmd_generate_filter(args: list[str]) -> int:
    if not args:
        return 129
    flen = (BITS_PER_ENTRY + 7) // 8
    filt = bytearray(flen)
    for item in args:
        hashes = bloom_hashes_for_string(item, HASH_VERSION)
        print("Hashes:" + "".join(f"0x{h:08x}|" for h in hashes))
        add_hashes_to_filter(hashes, filt)
    print_filter(filt)
    return 0

def add_path_and_parents(path: str, out: set[str]) -> None:
    p = path
    while p:
        out.add(p)
        if "/" not in p:
            break
        p = p.rsplit("/", 1)[0]

def cmd_get_filter_for_commit(args: list[str]) -> int:
    if len(args) != 1:
        return 129
    oid = args[0]
    parents_line = subprocess.run(
        ["git", "rev-list", "--parents", "-n", "1", oid],
        check=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    ).stdout.strip()
    parts = parents_line.split()
    parents = parts[1:]
    if parents:
        changed_out = subprocess.run(
            ["git", "diff-tree", "-r", "--name-only", "--no-commit-id", parents[0], oid],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        ).stdout
    else:
        changed_out = subprocess.run(
            ["git", "diff-tree", "-r", "--name-only", "--root", "--no-commit-id", oid],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        ).stdout

    changed_paths = [line for line in changed_out.splitlines() if line]
    pathset: set[str] = set()
    for p in changed_paths:
        add_path_and_parents(p, pathset)

    if len(pathset) > MAX_CHANGED_PATHS:
        filt = bytearray([0xFF])
        print_filter(filt)
        return 0

    flen = (len(pathset) * BITS_PER_ENTRY + 7) // 8
    if flen == 0:
        flen = 1
    filt = bytearray(flen)
    for p in pathset:
        hashes = bloom_hashes_for_string(p, HASH_VERSION)
        add_hashes_to_filter(hashes, filt)
    print_filter(filt)
    return 0

def main() -> int:
    if len(sys.argv) < 2:
        return 129
    subcmd = sys.argv[1]
    args = sys.argv[2:]
    if subcmd == "get_murmur3":
        return cmd_get_murmur3(args)
    if subcmd == "get_murmur3_seven_highbit":
        return cmd_get_murmur3_seven_highbit(args)
    if subcmd == "generate_filter":
        return cmd_generate_filter(args)
    if subcmd == "get_filter_for_commit":
        return cmd_get_filter_for_commit(args)
    return 129

sys.exit(main())
